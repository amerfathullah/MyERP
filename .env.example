# MyERP Production Environment Configuration
# Copy to .env and fill in actual values before deployment.
# NEVER commit .env to version control.

# Database
DB_USER=myerp
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=MyERP

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Container Registry
REGISTRY=ghcr.io
IMAGE_PREFIX=your-org/myerp
VERSION=latest

# API Configuration
API_URL=https://api.myerp.example.com
API_HOST=api.myerp.example.com
AUTH_AUTHORITY=https://api.myerp.example.com

# Angular App
APP_HOST=myerp.example.com
CORS_ORIGINS=https://myerp.example.com

# TLS / Let's Encrypt
ACME_EMAIL=admin@example.com
