# =============================================================================
# MyERP Self-Hosted Configuration
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
# Then run: docker compose up -d
# =============================================================================

# --- Docker Image Settings ---------------------------------------------------
# Your Docker Hub username or organization. Images: myerp-api, myerp-web, myerp-migrator
MYERP_IMAGE_PREFIX=amerfathullah
# Version tag. Use "latest" or pin a release like "1.0.0"
MYERP_VERSION=latest
# Registry (default: Docker Hub). Change for ghcr.io or private registries.
# MYERP_REGISTRY=docker.io

# --- Database ----------------------------------------------------------------
DB_USER=myerp
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=MyERP

# --- URLs --------------------------------------------------------------------
# Public URL where the API is accessible (used for OAuth issuer & CORS)
APP_URL=http://localhost:5000
# Public URL where the web frontend is accessible
WEB_URL=http://localhost

# --- Network -----------------------------------------------------------------
# Port to expose the web frontend on the host
HTTP_PORT=80

# --- Security ----------------------------------------------------------------
# Set to "true" if you're behind HTTPS (reverse proxy with TLS)
REQUIRE_HTTPS=false

# --- HTTPS with built-in Traefik (optional) ----------------------------------
# Use with: docker compose -f docker-compose.yml -f docker-compose.https.yml up -d
# DOMAIN=myerp.yourdomain.com
# ACME_EMAIL=admin@yourdomain.com

# =============================================================================
# ADVANCED (Optional)
# =============================================================================

# --- LHDN e-Invoice (Malaysia) ----------------------------------------------
# Uncomment and configure if using LHDN MyInvois integration
# LHDN__BaseUrl=https://myinvois.hasil.gov.my
# LHDN__ClientId=your_client_id
# LHDN__ClientSecret=your_client_secret
# LHDN__Environment=Production

# --- SMTP (Email Notifications) ---------------------------------------------
# SMTP__Host=smtp.example.com
# SMTP__Port=587
# SMTP__UserName=noreply@example.com
# SMTP__Password=email_password
# SMTP__EnableSsl=true
# SMTP__DefaultFromAddress=noreply@example.com
# SMTP__DefaultFromDisplayName=MyERP
